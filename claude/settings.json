{
  "includeCoAuthoredBy": false,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/mfaulk/.claude/hooks/gsd-check-update.js\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/status-line.sh"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "permissions": {
    "allow": [
      "Bash(date:*)",
      "Bash(pwd:*)",
      "Bash(whoami:*)",
      "Bash(which:*)",

      "Bash(echo:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(tr:*)",
      "Bash(find:*)",
      "Bash(xargs:*)",
      "Bash(awk:*)",

      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git remote -v:*)",
      "Bash(git fetch:*)",

      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git tag:*)"
    ]
  }
}
